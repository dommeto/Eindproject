arm = bpy.data.objects["Armature"]
pbone = arm.pose.bones["IK_Bone"]
target = bpy.data.objects["Target"]

bone_pos = arm.matrix_world @ pbone.head
target_pos = target.matrix_world.translation

direction = (target_pos - bone_pos).normalized()
rot_world = direction.to_track_quat('-Y', 'Z').to_matrix().to_4x4()
rot_arm = arm.matrix_world.inverted() @ rot_world
if pbone.parent:
    rot_parent_space = pbone.parent.matrix.inverted() @ rot_arm
else:
    rot_parent_space = rot_arm

rest_inv = pbone.bone.matrix_local.inverted()

pbone.matrix = rot_parent_space @ rest_inv
